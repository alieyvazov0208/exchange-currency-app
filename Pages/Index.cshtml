@page
@model CurrencyExchangeApp.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Font Awesome & Animate.css -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<div class="container text-center mt-5">
    <div class="p-4 rounded shadow-lg bg-dark bg-opacity-75 text-white animate__animated animate__fadeInDown">
        <h1 class="display-5">Welcome to MyCurrencyExchangeApp</h1>
        <p class="lead">Manage your currencies, trade easily, and stay updated with live exchange rates.</p>

        <div class="mt-3">
            <a class="btn btn-primary btn-lg me-3" asp-area="Identity" asp-page="/Account/Login">Login</a>
            <a class="btn btn-outline-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </div>

        <!-- 💶 Live EUR Rate -->
        <div class="alert alert-info mt-4 d-inline-block">
            💶 Live EUR → PLN: <strong>@Model.EurRate.ToString("0.00")</strong>
        </div>

        <div class="mt-4">
            <h4 class="text-white">What you can do:</h4>
            <ul class="list-unstyled text-start mx-auto" style="max-width: 320px;">
                <li><i class="fas fa-chart-line text-info me-2"></i> Live exchange rate tracking</li>
                <li><i class="fas fa-wallet text-success me-2"></i> Personal wallet management</li>
                <li><i class="fas fa-sync-alt text-warning me-2"></i> Fast currency conversion</li>
                <li><i class="fas fa-lock text-danger me-2"></i> Secure trading system</li>
            </ul>
        </div>

    </div>
</div>
