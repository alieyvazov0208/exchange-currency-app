@page
@model CurrencyExchangeApp.Pages.ConvertToPLNModel
@{
    ViewData["Title"] = "Currency Converter";
    var ratesJson = System.Text.Json.JsonSerializer.Serialize(Model.ExchangeRates);

    var flagMap = new Dictionary<string, string>
    {
        { "USD", "us" },
        { "EUR", "eu" },
        { "GBP", "gb" },
        { "CHF", "ch" },
        { "JPY", "jp" },
        { "PLN", "pl" }
    };
}

<h2>Live Currency Converter</h2>

<div class="row mb-4">
    <div class="col-md-6">
        <label>Amount</label>
        <input type="number" id="amount" class="form-control" step="0.01" value="1" />
    </div>

    <div class="col-md-3">
        <label>From</label>
        <select id="fromCurrency" class="form-select">
            @foreach (var code in Model.ExchangeRates.Keys)
            {
                <option value="@code">@code</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label>To</label>
        <select id="toCurrency" class="form-select">
            @foreach (var code in Model.ExchangeRates.Keys)
            {
                var selected = code == "PLN" ? "selected" : "";
                <option value="@code" selected="@selected">@code</option>
            }
        </select>
    </div>
</div>

<div class="mt-4">
    <h4>Result:</h4>
    <p id="result" class="fs-4">0.00</p>
</div>

<hr class="my-5" />

<h3>Live Exchange Rates (1 unit of currency in PLN)</h3>

<ul class="list-group">
    @foreach (var rate in Model.ExchangeRates)
    {
        if (rate.Key != "PLN")
        {
            var flag = flagMap.ContainsKey(rate.Key) ? flagMap[rate.Key] : "un";
            var flagUrl = $"https://flagcdn.com/24x18/{flag}.png";
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                    <img src="@flagUrl" class="me-2" />
                    <strong>@rate.Key</strong>
                </span>
                <span>1 @rate.Key = @rate.Value PLN</span>
            </li>
        }
    }
</ul>

@section Scripts {
<script>
    const rates = @Html.Raw(ratesJson);

    function updateConversion() {
        const amount = parseFloat(document.getElementById("amount").value);
        const from = document.getElementById("fromCurrency").value;
        const to = document.getElementById("toCurrency").value;

        if (!amount || amount <= 0 || !rates[from] || !rates[to]) {
            document.getElementById("result").innerText = "Invalid input";
            return;
        }

        const inPLN = amount * rates[from];     // Convert to PLN
        const converted = inPLN / rates[to];    // Convert PLN to target

        document.getElementById("result").innerText =
            `${amount} ${from} = ${converted.toFixed(2)} ${to}`;
    }

    document.getElementById("amount").addEventListener("input", updateConversion);
    document.getElementById("fromCurrency").addEventListener("change", updateConversion);
    document.getElementById("toCurrency").addEventListener("change", updateConversion);

    updateConversion(); // initial load
</script>
}
